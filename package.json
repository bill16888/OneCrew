{
  "name": "ai-native-team-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native Team Workspace MVP — Next.js 14 + Socket.io + Anthropic Agentic Loop",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "prisma generate && next build",
    "start": "tsx scripts/railway-start.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:backup": "tsx scripts/backup.ts",
    "docker:build": "docker build -t ai-workspace .",
    "docker:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:logs": "docker-compose -f docker-compose.prod.yml logs -f app"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@prisma/client": "5.19.1",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-slot": "1.1.0",
    "@sentry/nextjs": "^10.53.1",
    "bcryptjs": "2.4.3",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "lucide-react": "0.441.0",
    "next": "^14.2.35",
    "next-auth": "4.24.7",
    "node-cron": "^4.2.1",
    "openai": "^6.39.0",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "prisma": "5.19.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "socket.io": "4.7.5",
    "socket.io-client": "4.7.5",
    "tailwind-merge": "2.5.2",
    "tailwindcss-animate": "1.0.7",
    "tsx": "^4.22.3",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.16.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitest/mocker": "^3.2.4",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.35",
    "fast-check": "3.22.0",
    "jsdom": "25.0.1",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.12",
    "typescript": "5.5.4",
    "vitest": "^3.2.4"
  }
}
