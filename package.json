{
  "name": "onecrew",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native team workspace for human and AI teammates.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bill16888/OneCrew.git"
  },
  "bugs": {
    "url": "https://github.com/bill16888/OneCrew/issues"
  },
  "homepage": "https://github.com/bill16888/OneCrew#readme",
  "keywords": [
    "ai",
    "agents",
    "collaboration",
    "nextjs",
    "react",
    "prisma",
    "socket.io",
    "typescript"
  ],
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "prisma generate && next build",
    "start": "tsx scripts/railway-start.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:backup": "tsx scripts/backup.ts",
    "docker:build": "docker build -t ai-workspace .",
    "docker:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:logs": "docker-compose -f docker-compose.prod.yml logs -f app"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@prisma/client": "^6.12.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^10.53.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.21.0",
    "next": "^15.5.0",
    "next-auth": "^4.24.11",
    "node-cron": "^4.2.1",
    "openai": "^6.39.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.22.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/mocker": "^3.2.4",
    "eslint": "^9.30.0",
    "eslint-config-next": "^15.5.0",
    "fast-check": "^3.23.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
