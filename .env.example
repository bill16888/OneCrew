# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_workspace?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET MUST be at least 32 characters (validated by lib/env.ts).
# Generate one with: openssl rand -base64 48
NEXTAUTH_SECRET="your-32-char-secret-replace-me-please"

# --- DeepSeek (OpenAI-compatible chat completions API) ---
# DEEPSEEK_API_KEY: required, non-empty. Tokens issued from
# https://platform.deepseek.com — typically prefixed `sk-`.
DEEPSEEK_API_KEY="sk-your-deepseek-key-here"
# Override only if you point at a self-hosted gateway. Defaults to the
# public endpoint when unset (see lib/env.ts).
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# Chat model id. Common values: `deepseek-chat` (default),
# `deepseek-reasoner` (chain-of-thought variant).
DEEPSEEK_MODEL="deepseek-chat"

# --- Workspace (single hardcoded workspace, see Requirement 1.7) ---
WORKSPACE_ID="ws_default"

# --- Server ---
PORT=3000

# --- Realtime (browser-side Socket.io endpoint) ---
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# --- Redis (reserved for future task queue; not used by the MVP runtime) ---
REDIS_URL="redis://localhost:6379"

# --- AI runtime ---
# Daily token-cost ceiling in USD; the AI Runtime hard-stops once today's
# accumulated spend crosses this threshold (resets at UTC midnight).
AI_DAILY_BUDGET_USD=5
# Period of the Agentic Loop scheduler (ms).
AI_AGENT_INTERVAL_MS=30000

# --- Runtime mode ---
# Validated as one of: development | production | test
NODE_ENV=development

# --- Database backup (scripts/backup.ts + scripts/backup-cron.ts) ---
# All four BACKUP_* variables are OPTIONAL. When any of them is missing
# the cron prints a single warn log on boot and skips scheduling — the
# main service stays up. Configure them in production to enable the
# nightly 02:00 UTC pg_dump → S3/R2 upload pipeline.
BACKUP_STORAGE_URL=https://<accountid>.r2.cloudflarestorage.com
BACKUP_BUCKET_NAME=ai-workspace-backups
BACKUP_ACCESS_KEY_ID=
BACKUP_SECRET_ACCESS_KEY=
# Optional. Defaults to "auto" (Cloudflare R2). Override for AWS S3:
# BACKUP_REGION=us-east-1

# --- Sentry (error monitoring) ---
# DSN is generated when you create a Next.js project on sentry.io. When
# unset, Sentry is disabled and no events are uploaded — both
# `sentry.{client,server,edge}.config.ts` gate `enabled` on
# NODE_ENV === 'production', so dev sessions never ship events either.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=ai-workspace
# Optional. Used by the build to upload source maps; leave blank if
# you do not need symbolicated stack traces.
SENTRY_AUTH_TOKEN=
