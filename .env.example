# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_workspace?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET MUST be at least 32 characters (validated by lib/env.ts).
# Generate one with: openssl rand -base64 48
NEXTAUTH_SECRET="your-32-char-secret-replace-me-please"

# --- DeepSeek (OpenAI-compatible chat completions API) ---
# DEEPSEEK_API_KEY: required, non-empty. Tokens issued from
# https://platform.deepseek.com — typically prefixed `sk-`.
DEEPSEEK_API_KEY="sk-your-deepseek-key-here"
# Override only if you point at a self-hosted gateway. Defaults to the
# public endpoint when unset (see lib/env.ts).
DEEPSEEK_BASE_URL="https://api.deepseek.com"
# Chat model id. Common values: `deepseek-chat` (default),
# `deepseek-reasoner` (chain-of-thought variant).
# --- AI provider (Phase 1 Req 14) ---
# Which OpenAI-compatible backend to call. All three speak the OpenAI
# Chat Completions wire format, so switching is config-only.
#   deepseek (default) | openai | custom
# AI_PROVIDER=deepseek
#
# DeepSeek (default provider). Required when AI_PROVIDER=deepseek.
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
#
# OpenAI (or Azure OpenAI). Required when AI_PROVIDER=openai.
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"
#
# Custom OpenAI-compatible gateway (local vLLM / Ollama / LiteLLM /
# Claude-via-proxy). All three required when AI_PROVIDER=custom.
# AI_PROVIDER_API_KEY="..."
# AI_PROVIDER_BASE_URL="http://localhost:11434/v1"
# AI_PROVIDER_MODEL="llama3.1"
#
# NOTE: native Anthropic (Claude) is not yet a provider — its API is
# not OpenAI-compatible. Use AI_PROVIDER=custom with a compatible proxy.

# --- Workspace (single hardcoded workspace, see Requirement 1.7) ---
WORKSPACE_ID="ws_default"

# --- Brand decoupling (Phase 1 Req 16) ---
# Display name of the workspace, used by prisma:seed. In development
# this defaults to "Helio Demo Workspace" if unset; in production the
# seed REFUSES to run without it set explicitly.
# WORKSPACE_NAME="My Workspace"
#
# Browser-visible workspace name shown on the login page header. Inlined
# at build time (changing it requires a rebuild).
# NEXT_PUBLIC_WORKSPACE_NAME="My Workspace"
#
# Email domain for seeded users (e.g. mia@<domain>). Dev default:
# helio.local. Production requires it explicitly.
# SEED_EMAIL_DOMAIN="workspace.local"
#
# JSON array describing the seeded AI colleagues. Each entry needs a
# `name`; `id`, `aiRole`, and `mentionAliases` are optional. Dev default
# seeds Ada + Hopper with their Chinese aliases; production requires it.
# AI_AGENT_NAMES_JSON='[{"name":"Architect","aiRole":"engineer","mentionAliases":["架构师"]},{"name":"Coordinator","aiRole":"pm","mentionAliases":["协调员"]}]'
#
# Brand accent color. Override the --brand CSS variable in
# app/globals.css to re-skin without touching component classes.

# --- Server ---
PORT=3000

# --- Realtime (browser-side Socket.io endpoint) ---
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# --- Redis (reserved for future task queue; not used by the MVP runtime) ---
REDIS_URL="redis://localhost:6379"

# --- AI runtime ---
# Daily token-cost ceiling in USD; the AI Runtime hard-stops once today's
# accumulated spend crosses this threshold (resets at UTC midnight).
AI_DAILY_BUDGET_USD=5
# Period of the Agentic Loop scheduler (ms).
AI_AGENT_INTERVAL_MS=30000

# --- Wake-chain loop prevention (direction D, Req 22) ---
# Bounds the AI-to-AI wake tree that the assign_task hand-off tool
# (phase D2-b) introduces, so AI autonomy cannot spiral into a
# budget-burning A->B->A->B loop. Enforced by the single authorizeWake()
# chokepoint in lib/loop/wake-chain.ts. The dollar budget above stays an
# independent absolute backstop.
# Max relay DEPTH per chain (human -> A -> B -> ...).
AI_WAKE_MAX_HOPS=6
# Max times one ordered (fromAI -> toAI) edge may fire PER CHAIN; allows a
# finite hand-back while killing unbounded ping-pong.
AI_WAKE_MAX_PAIR_REPEATS=3
# Max TOTAL authorized wakes across the whole fan-out x depth tree; the
# real fan-out guard.
AI_WAKE_MAX_CHAIN_ACTIVATIONS=12

# --- AI daily report (Phase 1 Req 15) ---
# When true, each active AI posts an end-of-day digest to #general on a
# cron. Opt-in; default false.
# DAILY_REPORTS_ENABLED=false
# Crontab expression for the report (evaluated in WORKSPACE_TZ).
# Default 18:00 daily.
# DAILY_REPORT_CRON="0 18 * * *"
# IANA timezone for the cron. Default Asia/Shanghai.
# WORKSPACE_TZ="Asia/Shanghai"

# --- Operator dashboard (Phase 1 Req 13) ---
# When true, the workspace root (/) redirects to /dashboard. The
# dashboard route is always reachable directly regardless. Opt-in.
# DASHBOARD_ENABLED=false
# Per-million-token pricing fed to the budget tracker. Defaults to
# DeepSeek's published cache-MISS rates as of 2026-05; override when
# DeepSeek changes prices or when pinning a different model.
AI_INPUT_PRICE_PER_M_USD=1.07
AI_OUTPUT_PRICE_PER_M_USD=1.10
# System notice posted to #general when the daily budget trips. Override
# for non-Chinese deployments without redeploying.
# AI_BUDGET_EXCEEDED_NOTICE="⚠️ AI 今日预算已用尽，将于明日 UTC 0 点恢复"

# --- Realtime transports (browser-side override) ---
# Comma-separated list, default `websocket,polling`. Pin to `polling`
# only when the edge proxy strips the WS Upgrade header. Note: this is
# inlined into the client bundle by Next.js at build time, so changes
# require a rebuild + redeploy (not just a Railway env edit).
# NEXT_PUBLIC_SOCKET_TRANSPORTS=websocket,polling

# --- Seed user credentials (only consumed by `prisma:seed`) ---
# Required when NODE_ENV=production. The seed script throws if missing
# rather than fall back to the well-known demo password.
# SEED_HUMAN_PASSWORD=
# Optional override of bcrypt cost factor used when hashing seeded
# passwords. Defaults to 12; bumping past ~14 starts adding noticeable
# login latency (~600 ms / attempt at 14 on commodity CPU).
# SEED_BCRYPT_ROUNDS=12

# --- Schema deploy strategy (operator escape hatches) ---
# Default leaves this unset, which runs `prisma migrate deploy`. Set to
# `push` ONLY for greenfield bootstraps where you want db push --accept-
# data-loss to apply the schema directly. Never set this in steady state.
# PRISMA_DEPLOY_STRATEGY=migrate
# Comma-separated migration directory names that should be marked
# already-applied on the FIRST deploy that switches a `db push`-managed
# database to migration history. ONE-SHOT: unset after the first boot
# returns to green. List ONLY migrations whose schema is already in the
# live DB; listing a real new migration here will skip it silently.
# PRISMA_BASELINE_MIGRATIONS=0_init

# --- Real tools (Phase 1 Req 12) ---
# Tavily — AI-agent-tuned search, free tier covers 1000 queries/month.
# Sign up: https://app.tavily.com/home
TAVILY_API_KEY=
# Serper — Google SERP wrapper, used as fallback when WEB_SEARCH_PROVIDER=serper.
# Sign up: https://serper.dev/
SERPER_API_KEY=
# Provider selector: 'tavily' (default) or 'serper'.
WEB_SEARCH_PROVIDER=tavily
# USD charged per successful web_search call against the daily budget.
# Default 0.001 biases the breaker toward tripping a touch early.
WEB_SEARCH_COST_USD=0.001
# Optional GitHub PAT for the read_project_docs tool. Without it,
# requests go anonymously and share the 60 req/h unauthenticated
# rate limit (public repos only). With a token: 5000 req/h and
# access to private repos the token can read.
# Create one at https://github.com/settings/tokens (classic, `repo`
# scope) or use a fine-grained token scoped to specific repos.
GITHUB_TOKEN=

# --- Runtime mode ---
# Validated as one of: development | production | test
NODE_ENV=development

# --- Database backup (scripts/backup.ts + scripts/backup-cron.ts) ---
# All four BACKUP_* variables are OPTIONAL. When any of them is missing
# the cron prints a single warn log on boot and skips scheduling — the
# main service stays up. Configure them in production to enable the
# nightly 02:00 UTC pg_dump → S3/R2 upload pipeline.
BACKUP_STORAGE_URL=https://<accountid>.r2.cloudflarestorage.com
BACKUP_BUCKET_NAME=ai-workspace-backups
BACKUP_ACCESS_KEY_ID=
BACKUP_SECRET_ACCESS_KEY=
# Optional. Defaults to "auto" (Cloudflare R2). Override for AWS S3:
# BACKUP_REGION=us-east-1

# --- Sentry (error monitoring) ---
# DSN is generated when you create a Next.js project on sentry.io. When
# unset, Sentry is disabled and no events are uploaded — both
# `sentry.{client,server,edge}.config.ts` gate `enabled` on
# NODE_ENV === 'production', so dev sessions never ship events either.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org
SENTRY_PROJECT=ai-workspace
# Optional. Used by the build to upload source maps; leave blank if
# you do not need symbolicated stack traces.
SENTRY_AUTH_TOKEN=
