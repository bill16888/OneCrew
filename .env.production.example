# ============================================
# 生产环境配置模板
# 使用方法: 复制此文件为 .env,并填写真实值
# ============================================

# --- Database ---
# Railway 会自动注入 DATABASE_URL,本地开发需要手动设置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_workspace?schema=public"

# --- NextAuth ---
# ⚠️ 生产环境必须使用真实的域名(https://...)
NEXTAUTH_URL="https://你的域名.railway.app"

# ⚠️ 已生成新的安全密钥,请直接使用
NEXTAUTH_SECRET="FpX6JxKYiVaZ+tRu+W7ACMA/L0Sv9xeREhLgp7kaI3rtScS5dgjrqjmqxapVEbzP"

# --- DeepSeek (OpenAI-compatible) ---
# ❌ TODO: 替换为你的真实 DeepSeek API Key
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY="sk-你的真实key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# --- Workspace ---
WORKSPACE_ID="ws_default"

# --- Server ---
# Railway 会自动注入 PORT,不要手动设置
# PORT=3000

# --- Realtime ---
# ⚠️ 生产环境应该与 NEXTAUTH_URL 同源
NEXT_PUBLIC_SOCKET_URL="https://你的域名.railway.app"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- AI runtime ---
AI_DAILY_BUDGET_USD=5
AI_AGENT_INTERVAL_MS=30000

# --- Runtime mode ---
# ⚠️ 生产环境必须设置为 production
NODE_ENV=production

# --- Database backup (可选) ---
# BACKUP_STORAGE_URL="https://<accountid>.r2.cloudflarestorage.com"
# BACKUP_BUCKET_NAME="ai-workspace-backups"
# BACKUP_ACCESS_KEY_ID="你的access_key"
# BACKUP_SECRET_ACCESS_KEY="你的secret_key"
# BACKUP_REGION="auto"

# --- Sentry (可选但强烈推荐) ---
# ❌ TODO: 替换为你的真实 Sentry DSN
# 获取地址: https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oxx.ingest.sentry.io/xxx"
# SENTRY_ORG="你的组织名"
# SENTRY_PROJECT="ai-workspace"
# SENTRY_AUTH_TOKEN="你的auth_token"
