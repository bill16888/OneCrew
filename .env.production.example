# ============================================
# 生产环境配置模板
# 使用方法: 复制此文件为 .env,并填写真实值
# ============================================

# --- Database ---
# Railway 会自动注入 DATABASE_URL,本地开发需要手动设置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_workspace?schema=public"

# --- NextAuth ---
# ⚠️ 生产环境必须使用真实的域名(https://...)
NEXTAUTH_URL="https://你的域名.railway.app"

# Generate your own secret. Example: openssl rand -base64 48
NEXTAUTH_SECRET="replace-with-your-own-32-char-random-secret"

# --- DeepSeek (OpenAI-compatible) ---
# ❌ TODO: 替换为你的真实 DeepSeek API Key
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY="sk-你的真实key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
# AI provider 选择 (Phase 1 Req 14): deepseek(默认) | openai | custom
# 切到 OpenAI: 设 AI_PROVIDER=openai + OPENAI_API_KEY
# 切到本地/网关: 设 AI_PROVIDER=custom + AI_PROVIDER_API_KEY/BASE_URL/MODEL
# AI_PROVIDER=deepseek
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"

# --- Workspace ---
WORKSPACE_ID="ws_default"

# --- Server ---
# Railway 会自动注入 PORT,不要手动设置
# PORT=3000

# --- Realtime ---
# ⚠️ 生产环境应该与 NEXTAUTH_URL 同源
NEXT_PUBLIC_SOCKET_URL="https://你的域名.railway.app"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- AI runtime ---
AI_DAILY_BUDGET_USD=5
AI_AGENT_INTERVAL_MS=30000
# 模型定价 (USD per 1M tokens). 默认是 DeepSeek 2026-05 公布的非缓存命中价格.
AI_INPUT_PRICE_PER_M_USD=1.07
AI_OUTPUT_PRICE_PER_M_USD=1.10
# 预算耗尽时的系统提示 (留空使用默认中文文案).
# AI_BUDGET_EXCEEDED_NOTICE="⚠️ AI 今日预算已用尽，将于明日 UTC 0 点恢复"

# --- 唤醒链循环防护 (方向 D, Req 22) ---
# 约束 assign_task 交接工具 (D2-b 阶段) 引入的 AI->AI 唤醒树, 防止 AI 自驱
# 螺旋烧光预算. 由 lib/loop/wake-chain.ts 的单一 authorizeWake() 闸门强制执行;
# 上面的美元预算仍是独立的绝对兜底.
# 每条链的最大接力深度 (human -> A -> B -> ...).
AI_WAKE_MAX_HOPS=6
# 同一有序对 (fromAI -> toAI) 每条链最多触发次数; 允许有限回交, 挡住无限乒乓.
AI_WAKE_MAX_PAIR_REPEATS=3
# 整条链 (扇出 x 深度) 的最大授权唤醒总数; 真正管扇出的护栏.
AI_WAKE_MAX_CHAIN_ACTIVATIONS=12
# AI->AI 任务交接 (assign_task 工具) 总开关. false (默认) 时 assign_task 返回可恢复
# 错误且不发唤醒, 让唤醒链基础设施先在生产环境观察. 设 true 才允许一个 AI 把任务
# 派给队友 (受上面 AI_WAKE_* 预算约束).
AI_HANDOFF_ENABLED=false

# --- 种子用户凭据 (仅 prisma:seed 使用) ---
# ⚠️ 生产环境必填，否则 seed 直接报错拒绝使用 password123 默认值.
SEED_HUMAN_PASSWORD="生产环境用强密码"
# bcrypt rounds, 默认 12. 不建议 < 12 (OWASP 2024).
# SEED_BCRYPT_ROUNDS=12

# --- 品牌解耦 (Phase 1 Req 16, 仅 prisma:seed + 登录页使用) ---
# ⚠️ 生产环境必填，未设时 seed 拒绝种入 demo 品牌 (OneCrew/Ada/Hopper/onecrew.local).
WORKSPACE_NAME="My Workspace"
NEXT_PUBLIC_WORKSPACE_NAME="My Workspace"
SEED_EMAIL_DOMAIN="workspace.local"
AI_AGENT_NAMES_JSON='[{"name":"Architect","aiRole":"engineer","mentionAliases":["架构师"]},{"name":"Coordinator","aiRole":"pm","mentionAliases":["协调员"]}]'

# --- Runtime mode ---
# ⚠️ 生产环境必须设置为 production
NODE_ENV=production

# --- Database backup (可选) ---
# BACKUP_STORAGE_URL="https://<accountid>.r2.cloudflarestorage.com"
# BACKUP_BUCKET_NAME="ai-workspace-backups"
# BACKUP_ACCESS_KEY_ID="你的access_key"
# BACKUP_SECRET_ACCESS_KEY="你的secret_key"
# BACKUP_REGION="auto"

# --- Sentry (可选但强烈推荐) ---
# ❌ TODO: 替换为你的真实 Sentry DSN
# 获取地址: https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@oxx.ingest.sentry.io/xxx"
# SENTRY_ORG="你的组织名"
# SENTRY_PROJECT="ai-workspace"
# SENTRY_AUTH_TOKEN="你的auth_token"
