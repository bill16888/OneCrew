# Allow installs to proceed even when a peer dependency declares a
# range we don't strictly satisfy. We need this for `openai@6.x`,
# whose `peerOptional zod` declares `^3.25 || ^4`; our project ships
# `zod@3.23.8`, which is functionally compatible but technically
# outside the declared range. Without this flag, `npm ci` (the
# default install command in the production Dockerfile) fails inside
# the Railway / Docker build with an `ERESOLVE could not resolve`
# error before any code runs.
#
# This setting only relaxes the pre-install resolution check; runtime
# behaviour is unaffected. Any actually-incompatible peer would still
# manifest as a real import error during `npm run build`.
legacy-peer-deps=true
